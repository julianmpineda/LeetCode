# Write your MySQL query statement below

SELECT DISTINCT(A.num) AS ConsecutiveNums
FROM logs AS A
INNER JOIN logs AS B 
    ON A.id = B.id + 1
INNER JOIN logs AS C
    ON A.id = C.id + 2
WHERE A.num = B.num 
  AND A.num = C.num


