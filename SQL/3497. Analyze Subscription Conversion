/*
  A little more convoluted to weed out people who only did the 
  trial then cancelled. Select the id and 2 rounded averages from 
  the table where the activity types have both free trial and paid,
  grouped by users who have at least 2 distinct activity types.
*/

# Write your MySQL query statement below
SELECT user_id, 
    ROUND(AVG(
        CASE WHEN activity_type = 'free_trial' 
        THEN activity_duration END), 2) AS trial_avg_duration,
    ROUND(AVG(
        CASE WHEN activity_type = 'paid' 
        THEN activity_duration END), 2) AS paid_avg_duration
FROM UserActivity
WHERE activity_type IN ('free_trial', 'paid')
GROUP BY user_id
HAVING COUNT(DISTINCT activity_type) = 2
ORDER BY user_id
