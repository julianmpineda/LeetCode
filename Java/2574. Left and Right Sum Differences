class Solution {
    public int[] leftRightDifference(int[] nums) {
        int[] left = new int[nums.length];
        int sum = 0;

        for (int i = 0; i < nums.length; i++) {
            left[i] = sum;
            sum += nums[i];
        }

        int[] answer = new int[nums.length];

        for (int j = 0; j < nums.length; j++) {
            answer[j] = Math.abs(sum - nums[j] - 2*left[j]);
        }

        return answer;
    }
}
