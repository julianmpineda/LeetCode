class Solution {
    public int countHillValley(int[] nums) {
        int[] noRep = new int[nums.length];
        int count = 1, last = nums[0];
        noRep[0] = last;

        for (int i = 1; i < nums.length; i++) {
            if (nums[i] != last) {
                noRep[count] = nums[i];
                count++;
            }
            last = nums[i];
        }

        int total = 0;

        for (int i = 1; i < count - 1; i++) {
            int left = noRep[i - 1];
            int center = noRep[i];
            int right = noRep[i + 1];

            if (center > left && center > right) {
                total++;
            } else if ((center < left && center < right)) {
                total++;
            }
        }

        return total;
    }
}
