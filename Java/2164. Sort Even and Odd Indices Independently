class Solution {
    public int[] sortEvenOdd(int[] nums) {

        int n = nums.length;
        
        if (n < 3){
            return nums;
        }

        List<Integer> even = new ArrayList<>();
        List<Integer> odd = new ArrayList<>();

        for (int i = 0; i < n; i++) {
            if (i % 2 == 0) {
                even.add(nums[i]);
            } else {
                odd.add(nums[i]);
            }
        }

        Collections.sort(even);
        Collections.sort(odd);

        int e = 0, o = odd.size() - 1;
        int[] ans = new int[n];

        for (int j = 0; j < n; j++) {
            if (j % 2 == 0) {
                ans[j] = even.get(e);
                e++;
            } else {
                ans[j] = odd.get(o);
                o--;
            }
        }

        return ans;
    }
}
