class Solution {
    public double calculateTax(int[][] brackets, int income) {
        
        double tax = 0;
        int count = 0, bound = brackets[0][0];

        for (int i = 1; i < brackets.length; i++) {
            brackets[i][0] -= bound;
            bound += brackets[i][0];
        }

        while (income > 0) {
            if (income < brackets[count][0]) {
                tax += income * brackets[count][1];
                income = 0;
            } else {
                tax += brackets[count][0] * brackets[count][1];
                income -= brackets[count][0];
            }
            count++;
        }

        return tax / 100;
    }
}
