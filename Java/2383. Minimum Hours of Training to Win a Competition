class Solution {
    public int minNumberOfHours(int initialEnergy, int initialExperience, int[] energy, int[] experience) {
        int sumEng = 1, neededExp = 0;

        for (int i = 0; i < energy.length; i++) {
            sumEng += energy[i];

            if (experience[i] >= initialExperience) {
                int addExp = experience[i] - initialExperience + 1;
                initialExperience += addExp;
                neededExp += addExp;
            }
            
            initialExperience += experience[i];
        }

        if (initialEnergy < sumEng) {
            sumEng = sumEng - initialEnergy;
        } else {
            sumEng = 0;
        }

        return sumEng + neededExp;
    }
}
