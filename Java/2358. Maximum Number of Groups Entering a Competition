class Solution {
    public int maximumGroups(int[] grades) {
        
        int max = 0;

        for (int i = 1; i <= grades.length; i++) {
            max += i;

            if (max == grades.length) {
                return i;
            } else if (max > grades.length) {
                return i-1;
            }
        }

        return 0;
    }
}
