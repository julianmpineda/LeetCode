class Solution {
    public boolean isMonotonic(int[] nums) {
        boolean up = false, down = false;

        for (int i = 1; i < nums.length; i++) {
            // no change if equal to preceeding number.
            if (nums[i] > nums[i-1]) {
                up = true;
            } else if (nums[i] < nums[i-1]) {
                down = true;
            } 

            if (up && down) {
                return false;
            }
        }

        return true;
    }
}
