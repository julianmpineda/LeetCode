class Solution {
    public int bestClosingTime(String customers) {

        if (customers.indexOf('Y') == -1) {
            return 0;
        } else if (customers.indexOf('N') == -1) {
            return customers.length();
        }

        customers = '0' + customers;

        char[] c = customers.toCharArray();
        int min = 100001, hour = -1, yFull = 0;

        for (int i = 0; i < customers.length(); i++) {
            if (c[i] == 'Y') {
                yFull++;
            }
        }

        int nCount = 0, yCount = 0;

        for (int j = 0; j < c.length; j++) {
            
            if (c[j] == 'N') {
                nCount++;
            } else if (c[j] == 'Y') {
                yCount++;
            }

            int penalty = yFull - yCount + nCount;

            if (penalty < min) {
                min = penalty;
                hour = j;
            }
        }

        return hour;
    }
}
