class Solution {
    public int[] evenOddBit(int n) {
        int[] num = new int[2];
        int count = 0;

        while (n > 0) {
            if (n % 2 == 1) {
                if (count % 2 == 1) {
                    num[1]++;
                } else {
                    num[0]++;
                }
            }
            n /= 2;
            count++;
        }

        return num;
    }
}
