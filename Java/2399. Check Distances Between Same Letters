class Solution {
    public boolean checkDistances(String s, int[] distance) {
        int[] alpha = new int[26];

        for (int i = 0; i < s.length(); i++) {
            alpha[s.charAt(i) - 'a'] = i;
        }

        for (char c : s.toCharArray()) {
            if (alpha[c - 'a'] != -1) {
                if (alpha[c - 'a'] - s.indexOf(c) - 1 == distance[c - 'a']) {
                    alpha[c - 'a'] = -1;
                } else {            
                    return false;
                }
            }
        }
        return true;
    }
}
