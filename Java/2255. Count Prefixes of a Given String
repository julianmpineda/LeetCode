class Solution {
    public int countPrefixes(String[] words, String s) {
        int count = 0;

        for (int i = 0; i < words.length; i++) {
            int len = words[i].length();
            
            if (len > s.length() || words[i].charAt(0) != s.charAt(0)) {
                continue;
            } else if (words[i].equals(s.substring(0,len))) {
                count++;
            }
        }

        return count;
    }
}
