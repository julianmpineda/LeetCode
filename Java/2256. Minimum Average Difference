class Solution {
    public int minimumAverageDifference(int[] nums) {

        if (nums.length == 1) {
            return 0;
        }

        long pre = 0, post = 0, min = 100000;
        int ind = -1, len = nums.length, count = 0;

        for (int n : nums) {
            post += n;
        }

        for (int i = 0; i < nums.length; i++) {
            long diff = 100000;
            len--;
            count++;
            pre += nums[i];
            post -= nums[i];
            
            if (len > 0) {
                diff = Math.abs((pre/count) - (post / len));
            } else {
                diff = Math.abs((pre/count));
            }

            if (diff < min) {
                ind = i;
                min = diff;
            }
        }

        return ind;   
    }
}
