class Solution {
    public int minNumber(int[] nums1, int[] nums2) {
        int[] digits = new int[10];
        int min1 = 10, min2 = 10;

        for (int n : nums1) {
            digits[n]++;
            min1 = Math.min(min1, n);
        }

        for (int m : nums2) {
            digits[m]++;
            min2 = Math.min(min2, m);
        }

        for (int i = 0; i < 10; i++) {
            if (digits[i] > 1) {
                return i;
            }
        }

        if (min1 < min2) {
            return min1 * 10 + min2;
        } else {
            return min2 * 10 + min1;
        }
    }
}
