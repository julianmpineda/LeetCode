class Bitset {
    int[] bit;
    int count = 0, len = 0;
    boolean flipped = false;
    

    public Bitset(int size) {
        bit = new int[size];
        len = size;
    }
    
    public void fix(int idx) {
        if (!flipped) {
            count += bit[idx] == 0 ? 1 : 0;
            bit[idx] = 1;
        } else {
            count -= bit[idx] == 1 ? 1 : 0;
            bit[idx] = 0;
        }
    }
    
    public void unfix(int idx) {
        if (flipped) {
            count += bit[idx] == 0 ? 1 : 0;
            bit[idx] = 1;
        } else {
            count -= bit[idx] == 1 ? 1 : 0;
            bit[idx] = 0;
        }
    }
    
    public void flip() {
        flipped = !flipped;
    }
    
    public boolean all() {
        if (!flipped) {
            return (count == len);
        } else {
            return ((len - count) == len);
        }
    }
    
    public boolean one() {
        if (!flipped) {
            return (count > 0);
        } else {
            return ((len - count) > 0);
        }
    }
    
    public int count() {
        if (!flipped) {
            return (count);
        } else {
            return (len - count);
        }
    }
    
    public String toString() {
        StringBuilder num = new StringBuilder();

        if (flipped) {
            for (int b : bit) {
                num.append(((b + 1) % 2));
            }
        } else {
            for (int b : bit) {
                num.append(b);
            }
        }

        return num.toString();
    }
}

