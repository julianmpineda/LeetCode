class Solution {
    public int findPoisonedDuration(int[] timeSeries, int duration) {
        int total = 0;
        
        for (int i = 1; i < timeSeries.length; i++) {
            int time = timeSeries[i] - timeSeries[i - 1];
            total += Math.min(time, duration);
        }

        total += duration;

        return total;
    }
}
