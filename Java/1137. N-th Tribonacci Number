class Solution {
    public int tribonacci(int n) {
        int one = 0, two = 1, three = 1;

        if (n == 0) {
            return 0;
        } else if (n == 1 || n == 2) {
            return 1;
        }

        int nth = one + two + three;

        for (int i = 3; i <= n; i++) {
            nth = one + two + three;
            one = two;
            two = three;
            three = nth;
        }

        return nth;
    }
}
