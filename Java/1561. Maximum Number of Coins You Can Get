class Solution {
    public int maxCoins(int[] piles) {
        int coins = 0;
        Arrays.sort(piles);
        int offset = piles.length - 2;

        for (int i = 0; i < piles.length/3; i++) {
            coins += piles[offset];
            offset -= 2;
        }

        return coins;
    }
}
