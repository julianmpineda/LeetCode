class Solution {
    public long zeroFilledSubarray(int[] nums) {
        long sum = 0L;
        long cont = 0L;

        for (int i = 0; i < nums.length; i++) {
            if (nums[i] == 0) {
                cont++;
            } else {
                sum += (cont * (cont + 1)) / 2;
                cont = 0;
            }
        }
        sum += (cont * (cont + 1)) / 2;

        return sum;
    }
}
