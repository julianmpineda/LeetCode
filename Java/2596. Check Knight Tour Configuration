class Solution {
    public boolean checkValidGrid(int[][] grid) {
        
        if (grid[0][0] != 0) {
            return false;
        }

        Map<Integer, int[]> board = new HashMap<>();

        for (int i = 0; i < grid.length; i++) {
            for (int j = 0; j < grid[0].length; j++) {
                board.put(grid[i][j], new int[]{i, j});
            }
        }

        for (int m = 0; m < board.size() - 1; m++) {
            int[] pos = board.get(m);
            int[] next = board.get(m + 1);

            if (Math.abs(pos[0] - next[0]) == 1 && Math.abs(pos[1] - next[1]) == 2) {
                continue;
            } else if (Math.abs(pos[0] - next[0]) == 2 && Math.abs(pos[1] - next[1]) == 1) {
               continue;
            } else {
                return false;
            }
        }

        return true;
    }
}
