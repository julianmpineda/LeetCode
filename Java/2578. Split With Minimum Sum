class Solution {
    public int splitNum(int num) {
        int[] digits = new int[10];

        while (num > 0) {
            int n = num % 10;
            digits[n]++;
            num /= 10;
        }

        int a = 0, b = 0, swap = 0;

        for (int i = 1; i < 10; i++) {
            while (digits[i] > 0) {
                if (swap == 0) {
                    a += i;
                    digits[i]--;
                    a *= 10;
                    swap++;
                } else {
                    b += i;
                    digits[i]--;
                    b *= 10;
                    swap--;
                }
            }
        }

        return (a + b)/10;
    }
}
