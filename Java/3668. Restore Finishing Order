class Solution {
    public int[] recoverOrder(int[] order, int[] friends) {
        int[] rec = new int[friends.length];
        int count = 0;

        for (int i = 0; i < order.length; i++) {
            for (int j = 0; j < friends.length; j++) {
                if (order[i] == friends[j]) {
                    rec[count] = order[i];
                    count++;
                }
            }
        }

        return rec;
    }
}
