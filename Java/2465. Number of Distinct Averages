class Solution {
    public int distinctAverages(int[] nums) {
        Set<Double> avgs = new HashSet<>();

        Arrays.sort(nums);
        int start = 0, end = nums.length - 1;

        while (start < end) {
            double x = (nums[start] + nums[end]) / 2d;
            avgs.add(x);
            start++;
            end--;
        }

        return avgs.size();
    }
}
