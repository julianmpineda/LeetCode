class Solution {
    public int countAsterisks(String s) {

        if (s.indexOf('*') == -1) {
            return 0;
        }

        int count = 0;
        boolean pair = false;

        for (char c : s.toCharArray()) {

            if (c == '*' && !pair) {
                count++;
            } else if (c == '|') {
                pair = !pair;
            }
        }

        return count;
    }
}
