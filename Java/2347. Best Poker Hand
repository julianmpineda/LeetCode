class Solution {
    public String bestHand(int[] ranks, char[] suits) {
        
        int[] let = new int[5];
        int[] num = new int[14];

        for (int i = 0; i < 5; i++) {
            let[suits[i] - 'a']++;
            num[ranks[i]]++;

            if (let[suits[i] - 'a'] == 5) {
                return "Flush";
            }
        }
 
        int max = 0;

        for (int k = 1; k < 14; k++) {
            max = Math.max(max, num[k]);
        }

        if (max > 2) {
            return "Three of a Kind";
        } else if (max == 2) {
            return "Pair";
        } else {
            return "High Card";
        }
    }
}
