class Solution {
    public int[] answerQueries(int[] nums, int[] queries) {
        int count = 0;
        int[] sums = new int[nums.length];

        Arrays.sort(nums);

        for (int i = 0; i < nums.length; i++) {
            count += nums[i];
            sums[i] = count;
        }

        int[] answer = new int[queries.length];

        for (int j = 0; j < queries.length; j++) {
            int k = 0;
            while (k < sums.length && sums[k] <= queries[j]) {
                k++;
            }
            answer[j] = k;
        }

        return answer;
    }
}
