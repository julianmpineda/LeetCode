class Solution {
    public int minimumCardPickup(int[] cards) {
        Map<Integer, Integer> deck = new HashMap<>();
        int min = Integer.MAX_VALUE;

        for (int i = 0; i < cards.length; i++) {
            if (deck.containsKey(cards[i])) {
                min = Math.min(min, i - deck.get(cards[i]) + 1);
            } 
            deck.put(cards[i], i);
        }

        if (min > 100000) {
            return -1;
        }
        return min;
    }
}
