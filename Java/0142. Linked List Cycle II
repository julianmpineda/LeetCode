/**
 * Definition for singly-linked list.
 * class ListNode {
 *     int val;
 *     ListNode next;
 *     ListNode(int x) {
 *         val = x;
 *         next = null;
 *     }
 * }
 */
public class Solution {
    public ListNode detectCycle(ListNode head) {
        Set<ListNode> pass = new HashSet<>();

        if (head == null) {
            return null;
        }

        while (head.next != null) {
            
            if (pass.contains(head.next)) {
                return head.next;
            }

            pass.add(head);
            head = head.next;
        }

        return null;
    }
}
