class Solution {
    public List<String> summaryRanges(int[] nums) {
        
        List<String> summary = new ArrayList<>();

        if (nums.length == 0) {
            return summary;
        }

        StringBuilder range = new StringBuilder();
        range.append(nums[0]);
        int last = nums[0];
        int count = 0;

        for (int i = 1; i < nums.length; i++) {
            if (last + 1 == nums[i]) {
                last++;
                count++;
            } else { 
                if (count > 0) {
                    range.append("->");
                    range.append(last);
                }
                last = nums[i];
                count = 0;
                summary.add(range.toString());
                range.setLength(0);
                range.append(nums[i]);
            }
        }

        if (count > 0) {
            range.append("->");
            range.append(last);
        }
        summary.add(range.toString());

        return summary;
    }
}
