class Solution {
    public int numEquivDominoPairs(int[][] dominoes) {
        // Max domino is [9, 9] so max possible index is 99.
        int[] pairs = new int[100];
        int count = 0;

        for (int i = 0; i < dominoes.length; i++) {
            int[] d = dominoes[i];
            int dom = Math.max(d[0], d[1]) * 10 + Math.min(d[0], d[1]);

            // Each new match pairs with all previous instances.
            count += pairs[dom];
            pairs[dom]++;
        }

        return count;
    }
}
