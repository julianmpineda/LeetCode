  Two methods included. One is the original one I wrote that creates a
  'hash' based on first instance of a character irrespective to it's actual
  value. It then compares it. There was a test case specifically designed
  to trip up this method, which is why it also appends a '.' after each 
  character. The second one is the "fastest" submission on LC that I coded out
  and cleaned up just to get a feel for the logic used in it.
*/

class Solution {

     public List<String> findAndReplacePattern(String[] words, String pattern) {
        List<String> matches = new ArrayList<>();
        String cPattern = convert(pattern);

        for (String s : words) {
            if (cPattern.equals(convert(s))) {
                matches.add(s);
            }
        }

        return matches;
    }

    private static String convert(String s) {
        Map<Character, Integer> letters = new HashMap<>();
        StringBuilder convert = new StringBuilder();
        int count = 0;

        for (char c : s.toCharArray()) {
            if (!letters.keySet().contains(c)) {
                letters.put(c, count);
                count++;
            }
            convert.append(letters.get(c));
            convert.append('.');
        }

        return convert.toString();
    }

