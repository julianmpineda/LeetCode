class SmallestInfiniteSet {

    Set<Integer> removed;

    public SmallestInfiniteSet() {
        removed = new HashSet<>();
    }
    
    public int popSmallest() {

        int count = 1;
        
        while (removed.contains(count)) {
            count++;
        }
            
        removed.add(count);
        return count;
    }
    
    public void addBack(int num) {
        removed.remove(num);
    }
}

