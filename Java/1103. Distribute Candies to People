class Solution {
    public int[] distributeCandies(int candies, int num_people) {
        int[] people = new int[num_people];
        int count = 0;

        while (candies > 0) {
            for (int i = 0; i < num_people; i++) {
                int next = i + 1 + (count * num_people);
                if (candies < i + 1 + (count * num_people)) {
                    people[i] += candies;
                    candies -= candies;
                    break;
                } else {
                    people[i] += next;
                    candies -= next;
                }
            }
            count++;
        }

        return people;
    }
}
