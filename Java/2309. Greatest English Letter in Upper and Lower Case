class Solution {
    public String greatestLetter(String s) {

        for (char c = 'Z'; c >= 'A'; c--) {
            if ((s.indexOf(c) >= 0) && (s.indexOf(Character.toLowerCase(c)) >= 0)) {
                return String.valueOf(c);
            }
        }

        return "";

