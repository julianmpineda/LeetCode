class Solution {
    public int[] numSmallerByFrequency(String[] queries, String[] words) {
        int qLen = queries.length, wLen = words.length;
        int[] qCount = new int[qLen];
        int[] wCount = new int[wLen];

        for (int i = 0; i < qLen; i++) {
            qCount[i] = count(queries[i]);
        }

        for (int j = 0; j < wLen; j++) {
            wCount[j] = count(words[j]);
        }

        int[] count = new int[qLen];

        Arrays.sort(wCount);

        for (int m = 0; m < qLen; m++) {
            if (wLen == 1) {
                if (wCount[0] > qCount[m]) {
                    count[m] = 1;
                } else {
                    count[m] = 0;
                }
            } else {
                count[m] = wLen - binSearch(wCount, 0, wLen, qCount[m]);
            }
        }

        return count;
    }

    private static int count(String s) {
        int[] alpha = new int[26];

        for (char c : s.toCharArray()) {
            alpha[c - 'a']++;
        }

        for (int i = 0; i < 26; i++) {
            if (alpha[i] > 0) {
                return alpha[i];
            }
        }

        return -1;
    }

    private static int binSearch(int[] arr, int start, int end, int target) {
        int middle = (start + end) / 2, pre = middle - 1, post = middle + 1;

        if (start < end) {
            if ((pre >= 0) && (arr[middle] > target && arr[pre] <= target)) {
                return middle;
            } else if ((post < arr.length) && (arr[middle] <= target && arr[post] > target)) {
                return middle + 1;
            } else if ((post < arr.length) && (arr[middle] > target && arr[post] >= target)) {
                return binSearch(arr, start, middle - 1, target);
            } else {
                return binSearch(arr, middle + 1, end, target);
            }
        }

        return middle;    
    }

