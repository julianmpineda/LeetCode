class Solution {
    public int[] numSmallerByFrequency(String[] queries, String[] words) {
        int qLen = queries.length, wLen = words.length;
        int[] qCount = new int[qLen];
        int[] wCount = new int[wLen];

        for (int i = 0; i < qLen; i++) {
            qCount[i] = count(queries[i]);
        }

        for (int j = 0; j < wLen; j++) {
            wCount[j] = count(words[j]);
        }

        int[] count = new int[qLen];

/*      Working brute force method.

        for (int m = 0; m < qLen; m++) {
            for (int n = 0; n < wLen; n++) {
                if (qCount[m] < wCount[n]) {
                    count[m]++;
                }
            }
        }
*/
        Arrays.sort(wCount);

        int c = 0;

        for (int w : wCount) {
            System.out.print(c + " ");
            if (c < 10) { System.out.print(" ");}
            c++;
        }
        System.out.println();

        for (int w : wCount) {
            System.out.print(w + "  ");
        }
        System.out.println("\n---------------");

        for (int m = 0; m < qLen; m++) {

            if (wLen == 1) {
                if (wCount[0] > qCount[m]) {
                    count[m] = 1;
                } else {
                    count[m] = 0;
                }
            } else {
                count[m] = wLen - binSearch(wCount, 0, wLen, qCount[m] + 1);
            }
        }

        return count;
    }

    private static int count(String s) {
        int[] alpha = new int[26];

        for (char c : s.toCharArray()) {
            alpha[c - 'a']++;
        }

        for (int i = 0; i < 26; i++) {
            if (alpha[i] > 0) {
                return alpha[i];
            }
        }

        return -1;
    }

    private static int binSearch(int[] arr, int start, int end, int target) {
        int middle = (start + end - 1) / 2;
        System.out.println("search for " + target + " from " + start + " to " + end + " at " + middle);

        if (start < end && (middle + 1) < arr.length) {
            if ((middle - 1 >= 0) && (arr[middle] > target && arr[middle - 1] <= target)) {
                System.out.println("Found 1 at " + middle);
                return middle;
            } else if ((middle + 1 < arr.length) && (arr[middle] <= target && arr[middle + 1] > target)) {
                System.out.println("Found 2 at " + (middle + 1));
                return middle + 1;
            } else if (arr[middle] > target) {
                return binSearch(arr, start, middle - 1, target);
            } else if (arr[middle] < target || arr[middle] == target) {
                return binSearch(arr, middle + 1, end, target);
            }
        }

        return -1;    
    }
}
